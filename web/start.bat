@echo off
chcp 65001 
title 我的全栈项目启动器
color 0A

echo ==================================================
echo    正在启动项目...
echo ==================================================

:: 1. 启动后端 (Go)
echo [1/2] 正在启动后端服务...
:: 注意：这里加了 cd /d %~dp0\web，确保 go run 在正确的目录下执行
start "后端服务" cmd /k "cd /d %~dp0\web && go run main.go"

:: --- 新增代码开始 ---

:: 2. 等待 5 秒 (给 Go 程序编译和启动的时间)
echo 正在等待后端启动...
timeout /t 5 /nobreak >nul

:: 3. 打开浏览器跳转到指定网页
echo 正在打开网页...
start http://localhost:8081

:: --- 新增代码结束 ---

:: 4. 启动前端 (Node.js) - 如果你有前端的话
echo [2/2] 正在启动前端服务...
:: 注意：请确认你的前端代码是否真的在 web 目录下且有 package.json
:: 如果没有前端，可以把下面这行删掉或者注释掉（前面加 ::）
start "前端服务" cmd /k "cd /d %~dp0\web && npm run dev"

echo.
echo ==================================================
echo    所有服务已启动！请勿关闭黑色窗口。
echo ==================================================
pause